<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Barangay Greeting</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css">
</head>
<body>
  <section class="section">
    <div class="container" style="max-width: 480px;">
      <h1 class="title is-4">👋 Barangay Greeting</h1>

      <% if (locals.error) { %>
        <div class="notification is-danger"><%= error %></div>
      <% } %>

      <!-- NOTE: no `required` attribute here — the server must validate. -->
      <form action="/greet" method="POST" class="box">
        <div class="field">
          <label class="label" for="name">Your Name</label>
          <div class="control">
            <input id="name" name="name" class="input" type="text" placeholder="Juan dela Cruz">
          </div>
        </div>
        <button type="submit" class="button is-primary">Greet Me</button>
      </form>
    </div>
  </section>
</body>
</html>
