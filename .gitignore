# ─── Dependencies ─────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output ─────────────────────────────────
dist/
build/

# ─── Logs & runtime output ────────────────────────
# (Only ignore log *files* — the logs/ folder holds tracked .md docs)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment variables & secrets ──────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Operating system files ───────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ─────────────────────────────────
# Keep shared workspace config, ignore personal state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── Caches, coverage & temp ──────────────────────
.cache/
.npm/
.eslintcache
coverage/
.nyc_output/
.tmp/
tmp/

# ─── Misc ─────────────────────────────────────────
*.tgz
